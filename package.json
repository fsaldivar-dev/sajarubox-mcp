{
  "name": "sajarubox-mcp",
  "version": "1.25.1",
  "description": "MCP server — SajaruBox shared business rules and context",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "web": "node dist/web.js",
    "dev:web": "tsx src/web.ts",
    "dev:viewer": "cd viewer && npm run dev",
    "build:viewer": "cd viewer && npm install && npm run build",
    "web:custom": "node dist/web.js --path="
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
